// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // admin, editor, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartnerApplication {
  id              String   @id @default(cuid())
  organizationName String
  contactPerson   String
  email           String
  phone           String
  partnerType     String   // NGO, School, Church, LGU, Corporate Sponsor, Supplier, Diaspora Org, Technology Partner, Legal/Compliance
  website         String?
  description     String
  mission         String?
  howHeard        String?
  agreedToTerms   Boolean  @default(false)
  status          String   @default("pending") // pending, under_review, approved, rejected
  reviewNotes     String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  excerpt     String
  content     String   // JSON string of content paragraphs
  author      String
  authorRole  String
  readTime    String
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
